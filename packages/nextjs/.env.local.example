# Supabase Configuration (UCF Points System)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Replicate API for image generation
REPLICATE_API_TOKEN=your_replicate_token_here

# Admin Secret for UCF admin operations (verify fighters, etc.)
ADMIN_SECRET=your_admin_secret_here

# Optional entropy mode for Ichor Shower
ICHOR_ENTROPY_ENABLED=false
ICHOR_ENTROPY_PROGRAM_ID=entropy_program_pubkey_here
ICHOR_ENTROPY_VAR=entropy_var_pubkey_here
ICHOR_ENTROPY_PROVIDER=entropy_provider_pubkey_here
ICHOR_ENTROPY_AUTHORITY=entropy_var_authority_pubkey_here

# Hard-reset defaults (recommended when redeploying fresh)
MAGICBLOCK_ER_ENABLED=true
MAGICBLOCK_ER_RPC_URL=https://devnet-router.magicblock.app
MAGICBLOCK_ER_VALIDATOR_PUBKEY=MUS3hc9TCw4cGC12vHNoYcCGzJG1txjgQLZWVoeNHNd
MAGICBLOCK_ER_VALIDATOR_RPC_URL=https://devnet-us.magicblock.app
NEXT_PUBLIC_RUMBLE_ENGINE_PROGRAM=your_new_rumble_engine_program_id
# Enable this when you want turn resolution and matchup pairing to use the
# on-chain combat flow (including VRF-backed matchup seeds).
RUMBLE_ONCHAIN_TURN_AUTHORITY=true
RUMBLE_ALLOW_LEGACY_FALLBACK=false
RUMBLE_REQUIRE_MATCHUP_VRF=true
RUMBLE_MATCHUP_VRF_TIMEOUT_MS=60000
RUMBLE_REQUIRE_SHOWER_VRF=true
