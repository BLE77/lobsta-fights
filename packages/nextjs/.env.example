# =============================================================================
# UCF (Underground Claw Fights) - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Lines with "# ..." after the = are descriptions, not default values.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=# Your Supabase project URL (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=# Supabase anon/public key (safe for browser)
SUPABASE_SERVICE_ROLE_KEY=# Supabase service role key (server-side only, never expose to client)

# -----------------------------------------------------------------------------
# Solana / ICHOR Token System
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HELIUS_API_KEY=# Helius API key for Solana RPC and wallet services (https://dev.helius.xyz)
NEXT_PUBLIC_SOLANA_NETWORK=# Solana cluster: devnet | mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=# Optional explicit Solana RPC URL override for web/mobile clients
NEXT_PUBLIC_ICHOR_TOKEN_MINT=# SPL token mint address for ICHOR token

# Solana Program IDs (from Anchor.toml - devnet defaults shown)
NEXT_PUBLIC_FIGHTER_REGISTRY_PROGRAM=# Fighter Registry program ID (default: 2hA6Jvj1yjP2Uj3qrJcsBeYA2R9xPM95mDKw1ncKVExa)
NEXT_PUBLIC_RUMBLE_ENGINE_PROGRAM=# Rumble Engine program ID (default: 2TvW4EfbmMe566ZQWZWd8kX34iFR2DM3oBUpjwpRJcqC)
NEXT_PUBLIC_ICHOR_TOKEN_PROGRAM=# ICHOR Token program ID (default: 925GAeqjKMX4B5MDANB91SZCvrx8HpEgmPJwHJzxKJx1)
# Optional server-side aliases for the same IDs
FIGHTER_REGISTRY_PROGRAM_ID=# Optional server-side alias for NEXT_PUBLIC_FIGHTER_REGISTRY_PROGRAM
RUMBLE_ENGINE_PROGRAM_ID=# Optional server-side alias for NEXT_PUBLIC_RUMBLE_ENGINE_PROGRAM
ICHOR_TOKEN_PROGRAM_ID=# Optional server-side alias for NEXT_PUBLIC_ICHOR_TOKEN_PROGRAM

# MagicBlock ER (set false for hard-reset/redeploy until ER path is validated)
MAGICBLOCK_ER_ENABLED=# true | false (recommended default after reset: false)
MAGICBLOCK_ER_RPC_URL=# ER router endpoint (example: https://devnet-router.magicblock.app)
MAGICBLOCK_ER_VALIDATOR_PUBKEY=# Optional explicit validator identity to pin delegation to one ER region
MAGICBLOCK_ER_VALIDATOR_RPC_URL=# Optional explicit validator RPC for log parsing/recovery (example: https://devnet-us.magicblock.app)
MAGICBLOCK_ER_ESCROW_MIN_SOL=# Optional min escrow SOL target (default: 0.02)
MAGICBLOCK_ER_ESCROW_TOPUP_MAX_SOL=# Optional max SOL top-up per delegation (default: 0.05)
MAGICBLOCK_ER_VALIDATOR_CACHE_TTL_MS=# Optional closest-validator cache TTL (default: 60000)
RUMBLE_ALLOW_LEGACY_FALLBACK=# true | false (recommended: false)
RUMBLE_REQUIRE_MATCHUP_VRF=# true | false (recommended: true)
RUMBLE_MATCHUP_VRF_RETRY_MS=# Retry interval while waiting for matchup VRF seed (default: 5000)
RUMBLE_MATCHUP_VRF_TIMEOUT_MS=# Abort rumble if matchup VRF seed never arrives (default: 60000)
RUMBLE_REQUIRE_SHOWER_VRF=# true | false (recommended: true)
RUMBLE_PAYOUT_MODE=# instant | accrue_claim (recommended: accrue_claim)
RUMBLE_AUTO_TICK=# true | false (default: true in dev, false in prod)
RUMBLE_AUTO_TICK_INTERVAL_MS=# Auto tick interval (default: 2000)
RUMBLE_COMBAT_TICK_INTERVAL_MS=# Turn pacing in combat (default: 3000)
RUMBLE_BETTING_DURATION_MS=# Betting window per rumble (default: 60000)
FIGHTERS_PER_RUMBLE=# Max fighters locked into each rumble before on-chain create (default: 12, hard max: 16)
RUMBLE_MIN_FIGHTERS_TO_START=# Minimum queued fighters required to begin the pre-start lock countdown (default: 12)
RUMBLE_QUEUE_LOCK_COUNTDOWN_MS=# Fill window after reaching the minimum before the rumble locks and starts (default: 30000)
RUMBLE_BETTING_CLOSE_GRACE_MS=# Extra delay after deadline before combat transition (default: 1500)
RUMBLE_ALLOW_OFFCHAIN_BETS=# true | false (default: false; keep false for full on-chain security)
RUMBLE_COMBAT_DURATION_MS=# Safety max combat duration (default: 300000)
RUMBLE_PAYOUT_DURATION_MS=# Payout display window (default: 30000)
RUMBLE_TICKS_PER_INVOCATION=# Tick burst size for /api/rumble/tick (default: 8)
RUMBLE_TICK_BURST_INTERVAL_MS=# Delay between burst ticks (default: 1000)
RUMBLE_HOUSE_BOTS_ENABLED=# true | false (default: false). Auto-fill queue with house bots when no real fighters are present.
RUMBLE_HOUSE_BOT_IDS=# Comma-separated fighter IDs pre-registered in ucf_fighters (example: id1,id2,...)
RUMBLE_HOUSE_BOT_TARGET_POPULATION=# Desired total house fighters across queue+active slots when idle (default: 12; keep below FIGHTERS_PER_RUMBLE if you want room for humans)
RUMBLE_HOUSE_BOTS_AUTO_FILL=# true | false (default: false). Set true to enable auto-fill; otherwise use the admin "Start Test Run" button.
RUMBLE_WORKER_IDLE_INTERVAL_MS=# Worker tick interval while all slots are idle (default: 15000)
UCF_WEBHOOK_SHARED_SECRET=# Shared HMAC secret for outbound webhook signatures (X-UCF-Signature)
HOUSE_BOT_REQUIRE_SIGNATURE=# true | false (default: true if UCF_WEBHOOK_SHARED_SECRET is set)
HOUSE_BOT_SIGNATURE_MAX_SKEW_SECONDS=# Max allowed webhook timestamp skew for house bot verification (default: 300)
HOUSE_BOT_ALLOWED_FIGHTER_IDS=# Optional comma-separated fighter allowlist for /api/house-bot/fight
HOUSE_BOT_STRATEGY_SEED=# Secret seed for deterministic house-bot move generation (defaults to UCF_WEBHOOK_SHARED_SECRET)

# Vault
NEXT_PUBLIC_RUMBLE_VAULT_ADDRESS=# PDA vault address for rumble bets/escrow

# Solana Mobile / Seeker TWA verification
TWA_PACKAGE_NAME=# Android package id (default: xyz.clawfights.twa)
TWA_SHA256_CERT_FINGERPRINTS=# Comma-separated SHA256 cert fingerprints for /.well-known/assetlinks.json
NEXT_PUBLIC_TWA_SHA256_CERT_FINGERPRINTS=# Optional public fallback if server env is not set
UCF_WALLET_ALLOWLIST=# Optional comma-separated wallet allowlist for instant fighter auto-approval
SEEKER_GENESIS_COLLECTION_MINT=# Optional Seeker Genesis collection mint for auto-approving Seeker wallets
SEEKER_GENESIS_VERIFIED_CREATOR=# Optional verified creator address for Seeker Genesis asset matching
SEEKER_GENESIS_UPDATE_AUTHORITY=# Optional update authority address for Seeker Genesis asset matching

# Optional: external entropy for Ichor Shower (recommended for production fairness)
# When enabled, server will configure on-chain entropy settings and pass entropy accounts
# into checkIchorShower settlement calls.
ICHOR_ENTROPY_ENABLED=# true | false
ICHOR_ENTROPY_PROGRAM_ID=# Entropy program ID (e.g., entropy_api program)
ICHOR_ENTROPY_VAR=# Entropy var account public key
ICHOR_ENTROPY_PROVIDER=# Authorized entropy provider public key
ICHOR_ENTROPY_AUTHORITY=# Entropy var authority pubkey (must match Var.authority)

# -----------------------------------------------------------------------------
# Image Generation (Replicate)
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN=# Replicate API token for Flux image generation (https://replicate.com/account/api-tokens)

# -----------------------------------------------------------------------------
# Base Chain / EVM (legacy wager system)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_ALCHEMY_RPC_URL_MAINNET=# Alchemy RPC URL for Base mainnet
NEXT_PUBLIC_USE_BASE_TESTNET=# Set to "true" to use Base Sepolia testnet
NEXT_PUBLIC_UCF_CONTRACT=# UCF contract address (Base testnet)
NEXT_PUBLIC_UCF_CONTRACT_MAINNET=# UCF contract address (Base mainnet)
BASE_SEPOLIA_RPC_URL=# Base Sepolia RPC URL (server-side, optional)
BASE_RPC_URL=# Base mainnet RPC URL (server-side, optional)
WAGER_CONTRACT_ADDRESS=# Wager contract address (server-side)
ARBITER_PRIVATE_KEY=# Arbiter wallet private key for settling wagers (server-side, never expose)

# -----------------------------------------------------------------------------
# Admin / Internal
# -----------------------------------------------------------------------------
ADMIN_SECRET=# Secret for admin API routes (verify fighters, regenerate images, etc.)
UCF_INTERNAL_KEY=# Internal key for server-to-server match notification calls
CRON_SECRET=# Vercel cron secret for /api/cron/* and /api/matchmaker/run

# -----------------------------------------------------------------------------
# AI Commentary (Anthropic + ElevenLabs TTS)
# -----------------------------------------------------------------------------
RUMBLE_COMMENTARY_MODE=grounded # grounded (default, zero hallucinations) | llm
ANTHROPIC_API_KEY=# Anthropic API key for Claude Haiku commentary generation
ELEVENLABS_API_KEY=# ElevenLabs API key for real-time TTS commentary
ELEVENLABS_VOICE_A=# ElevenLabs voice ID for announcer voice A
ELEVENLABS_VOICE_B=# ElevenLabs voice ID for announcer voice B (A/B testing)
NEXT_PUBLIC_ELEVENLABS_VOICE_A=# Voice A ID (client-side, for voice selector)
NEXT_PUBLIC_ELEVENLABS_VOICE_B=# Voice B ID (client-side, for voice selector)

# -----------------------------------------------------------------------------
# Optional / Third-Party
# -----------------------------------------------------------------------------
MOLTBOOK_APP_KEY=# MoltBook integration key (optional)
